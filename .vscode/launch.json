    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/binaries/tool_ToCpp",
            "args": [
                "${workspaceFolder}/test/integration/BasicTest/BasicTypes.cxx",
                "${workspaceFolder}/test/integration/BasicTest/MathUtils.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Geometry.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector2.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector3.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector4.cxx",
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "compiler build debug"
        },
        {
            "name": "Release",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/binaries/tool_ToCpp",
            "args": [
                "${workspaceFolder}/test/integration/BasicTest/BasicTypes.cxx",
                "${workspaceFolder}/test/integration/BasicTest/MathUtils.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Geometry.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector2.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector3.cxx",
                "${workspaceFolder}/test/integration/BasicTest/Vector4.cxx",
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "compiler build release"
        }
    ]
}